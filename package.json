services:
  - type: web
    name: pucl08rebirth-api
    runtime: node
    buildCommand: corepack enable && corepack prepare pnpm@10.4.1 --activate && pnpm install && pnpm run build
    startCommand: pnpm run start
    envVars:
      - key: NODE_ENV
        value: production
      - key: DATABASE_URL
        fromDatabase:
          name: pucl08rebirth-db
          property: connectionString
      - key: JWT_SECRET
        generateValue: true
      - key: VITE_APP_ID
        sync: false
      - key: OAUTH_SERVER_URL
        sync: false
      - key: BUILT_IN_FORGE_API_URL
        sync: false
      - key: BUILT_IN_FORGE_API_KEY
        sync: false
      - key: OWNER_OPEN_ID
        sync: false

databases:
  - name: pucl08rebirth-db
    plan: free
